pipeline: devobs_enrich
# Enrich the knowledge graph with LLM-suggested project relationships.
#
# 1. Gathers all project metadata
# 2. Calls OpenAI to suggest new relationships
# 3. Outputs candidates to .ctx/enrich_candidates.json for human review
# 4. Does NOT auto-ingest — run `rust-script scripts/devobs.rs apply` after review
#
# Requires: OPENAI_API_KEY via dotenvx (~/dev/.env)
#
# Run:
#   crux run pipelines/devobs_enrich.crux
budget: { calls: 10 }

steps:
  - step: suggest_relationships
    handler: shell::capture
    args:
      cmd: "dotenvx run -f /Users/joe/dev/.env -- rust-script scripts/devobs.rs enrich > .ctx/enrich_candidates.json"

  - step: report
    handler: shell::capture
    args:
      cmd: "jq length .ctx/enrich_candidates.json | xargs -I{} echo '{} candidates written to .ctx/enrich_candidates.json'"
